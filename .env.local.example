# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_URI=

# Bcrypt hash of your single password (generate with: npm run hash)
APP_PASSWORD_HASH=

# Random 32+ character string for iron-session cookie signing
# Generate with: openssl rand -base64 48
SESSION_SECRET=

# Local timezone for heatmap day-bucketing (IANA name)
NEXT_PUBLIC_TIMEZONE=America/New_York

# Optional: override the database name (defaults to fluent_in_code)
# MONGODB_DB=fluent_in_code
